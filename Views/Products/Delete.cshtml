@model Product_Management.Models.Product
@{
    ViewData["Title"] = "Delete Product";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>Confirm Delete
                </h5>
            </div>
            <div class="card-body text-center p-4">
                @if (!string.IsNullOrEmpty(Model.ImagePath))
                {
                    <img src="@Model.ImagePath" class="rounded mb-3"
                         style="max-width:150px;max-height:150px;object-fit:cover;" />
                }
                <h4>@Model.Name</h4>
                <p class="text-muted">@Model.Description</p>
                <p>
                    <strong>Price:</strong> $@Model.Price.ToString("N2") &nbsp;|&nbsp;
                    <strong>Category:</strong> @Model.Category?.Name
                </p>

                <div class="alert alert-warning">
                    <i class="bi bi-info-circle me-2"></i>
                    This will also <strong>delete the product image</strong> permanently.
                </div>

                <form asp-action="Delete" method="post" class="d-flex justify-content-center gap-3">
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">
                        <i class="bi bi-x-lg me-1"></i>Cancel
                    </a>
                    <button type="submit" class="btn btn-danger px-4">
                        <i class="bi bi-trash me-1"></i>Yes, Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>