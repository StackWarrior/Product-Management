@model Product_Management.Models.Product
@{
    ViewData["Title"] = Model.Name;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-box-seam me-2"></i>@Model.Name</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i>Back
    </a>
</div>

<div class="row g-4">
    <div class="col-md-4 text-center">
        @if (!string.IsNullOrEmpty(Model.ImagePath))
        {
            <img src="@Model.ImagePath" class="img-fluid rounded shadow-sm" />
        }
        else
        {
            <div class="p-5 bg-light rounded text-muted">
                <i class="bi bi-image" style="font-size:4rem"></i>
                <p>No image</p>
            </div>
        }
    </div>
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <dl class="row">
                    <dt class="col-sm-4">Name</dt>
                    <dd class="col-sm-8">@Model.Name</dd>

                    <dt class="col-sm-4">Category</dt>
                    <dd class="col-sm-8">
                        <span class="badge bg-primary">@Model.Category?.Name</span>
                    </dd>

                    <dt class="col-sm-4">Price</dt>
                    <dd class="col-sm-8 text-success fw-bold">$@Model.Price.ToString("N2")</dd>

                    <dt class="col-sm-4">Stock</dt>
                    <dd class="col-sm-8">@Model.Stock units</dd>

                    <dt class="col-sm-4">Description</dt>
                    <dd class="col-sm-8">@Model.Description</dd>

                    <dt class="col-sm-4">Created</dt>
                    <dd class="col-sm-8 text-muted">@Model.CreatedAt.ToString("MMM dd, yyyy")</dd>
                </dl>

                <div class="d-flex gap-2 mt-3">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger">
                        <i class="bi bi-trash me-1"></i>Delete
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>