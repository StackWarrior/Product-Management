@model IEnumerable<Product_Management.Models.Product>
@{
    ViewData["Title"] = "Products";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-box-seam me-2"></i>Products</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Add Product
    </a>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5">
        <i class="bi bi-inbox" style="font-size:3rem;color:#ccc"></i>
        <p class="mt-3 text-muted">No products yet. <a asp-action="Create">Add one!</a></p>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Category</th>
                        <th>Price</th>
                        <th>Stock</th>
                        <th>Created</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var product in Model)
                    {
                        <tr>
                            <td class="align-middle">
                                @if (!string.IsNullOrEmpty(product.ImagePath))
                                {
                                    <img src="@product.ImagePath" width="55" height="55"
                                         style="object-fit:cover;border-radius:8px;border:2px solid #e2e8f0;" />
                                }
                                else
                                {
                                    <div style="width:55px;height:55px;background:#f1f5f9;border-radius:8px;
                                                            border:2px dashed #cbd5e1;display:flex;align-items:center;
                                                            justify-content:center;color:#94a3b8;">
                                        <i class="bi bi-image fs-4"></i>
                                    </div>
                                }
                            </td>
                            <td class="align-middle fw-semibold">@product.Name</td>
                            <td class="align-middle">
                                <span class="badge bg-primary">@product.Category?.Name</span>
                            </td>
                            <td class="align-middle text-success fw-bold">
                                $@product.Price.ToString("N2")
                            </td>
                            <td class="align-middle">
                                <span class="badge @(product.Stock > 10 ? "bg-success" : product.Stock > 0 ? "bg-warning text-dark" : "bg-danger")">
                                    @product.Stock
                                </span>
                            </td>
                            <td class="align-middle text-muted small">
                                @product.CreatedAt.ToString("MMM dd, yyyy")
                            </td>
                            <td class="align-middle text-center">
                                <a asp-action="Details" asp-route-id="@product.Id"
                                   class="btn btn-sm btn-outline-secondary me-1" title="Details">
                                    <i class="bi bi-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@product.Id"
                                   class="btn btn-sm btn-outline-primary me-1" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-action="Delete" asp-route-id="@product.Id"
                                   class="btn btn-sm btn-outline-danger" title="Delete">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
